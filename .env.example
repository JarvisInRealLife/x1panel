# Copy to .env and fill in values. On Render, set these in Dashboard → Environment.

# Required: login credentials (no defaults - set in Render)
X1_USERNAME=your_username
X1_PASSWORD=your_password

# Required: session secret (generate a long random string)
SECRET_KEY=your-long-random-secret-key-here

# Required: external API
API_KEY=SHIVAM
API_BASE_URL=https://aetherosint.site/cutieee/api.php

# Optional: port (Render sets PORT automatically)
# PORT=5000
